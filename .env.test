# 测试环境变量（提测 / 联调）
#
# 注意「构建优化口径」与 APP_ENV 的解耦：
#   - 测试包用 `pnpm build`（生产级优化：压缩、长效缓存指纹）产出，
#     与生产包构建口径一致，避免「测试环境没压缩、上线才暴露问题」。
#     该口径由构建工具原生注入（import.meta.env.PROD / NODE_ENV），无需手动维护。
#   - APP_ENV=test：业务逻辑据此指向测试服务，与「构建优化口径」分开。

# 应用环境：业务侧识别为测试环境
APP_ENV=test

# 接口基地址（示例占位，按需替换为真实测试地址）
PUBLIC_API_BASE_URL=https://test-api.example.com/api
