{
  "name": "lystack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "description": "构建工具无关的企业级 Vue3 Monorepo 底座（Vite / Rsbuild 可插拔）",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vue-eslint-parser": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
