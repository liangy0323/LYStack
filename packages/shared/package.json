{
  "name": "@repo/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "构建工具无关的共享层：env / utils / types / constants",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts",
    "./constants": "./src/constants/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
